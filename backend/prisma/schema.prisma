generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============ Auth ============

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  isAdmin   Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ============ Master Data ============

model Vendor {
  id         String   @id @default(cuid())
  vendorCode String   @unique
  name       String
  address    String?
  taxId      String?
  aliases    String[]
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  documents  Document[]
  matchSets  MatchSet[]
}

model InventoryItem {
  id          String   @id @default(cuid())
  itemCode    String   @unique
  description String
  uom         String?
  aliases     String[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ============ Documents ============

enum DocumentType {
  PO
  DO
  INVOICE
}

enum DocumentStatus {
  UPLOADED
  CLASSIFYING
  EXTRACTING
  EXTRACTED
  MATCHING
  MATCHED
  EXCEPTION
  REVIEWED
  EXPORTED
}

model Document {
  id                  String         @id @default(cuid())
  type                DocumentType
  status              DocumentStatus @default(UPLOADED)
  vendorId            String?
  vendor              Vendor?        @relation(fields: [vendorId], references: [id])

  documentNumber      String?
  documentDate        DateTime?

  originalFileName    String
  filePath            String
  pageCount           Int?

  rawOcrText          String?
  extractedData       Json?
  extractionConfidence Float?

  vendorName          String?
  vendorAddress       String?
  subtotal            Decimal?       @db.Decimal(18, 4)
  taxAmount           Decimal?       @db.Decimal(18, 4)
  totalAmount         Decimal?       @db.Decimal(18, 4)
  discount            Decimal?       @db.Decimal(18, 4)
  currency            String?        @default("MYR")

  lineItems           DocumentLineItem[]
  matchSetLinks       MatchSetDocument[]
  exceptions          MatchException[]

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  createdById         String?

  @@index([vendorId, type])
  @@index([documentNumber])
  @@index([status])
}

model DocumentLineItem {
  id               String    @id @default(cuid())
  documentId       String
  document         Document  @relation(fields: [documentId], references: [id], onDelete: Cascade)

  lineNumber       Int
  itemCode         String?
  description      String?
  quantity         Decimal?  @db.Decimal(18, 4)
  uom              String?
  unitPrice        Decimal?  @db.Decimal(18, 4)
  amount           Decimal?  @db.Decimal(18, 4)
  discount         Decimal?  @db.Decimal(18, 4)
  taxCode          String?
  taxAmount        Decimal?  @db.Decimal(18, 4)

  fieldConfidence  Json?
  resolvedItemId   String?

  lineMatches      LineMatch[] @relation("POLine")
  doLineMatches    LineMatch[] @relation("DOLine")
  invLineMatches   LineMatch[] @relation("InvoiceLine")

  @@unique([documentId, lineNumber])
}

// ============ Matching ============

enum MatchSetStatus {
  PENDING
  AUTO_MATCHED
  REVIEW_NEEDED
  EXCEPTION
  REVIEWED
  EXPORTED
}

model MatchSet {
  id              String          @id @default(cuid())
  vendorId        String
  vendor          Vendor          @relation(fields: [vendorId], references: [id])
  poNumber        String

  status          MatchSetStatus  @default(PENDING)
  confidenceScore Float?

  toleranceConfig Json?

  documents       MatchSetDocument[]
  lineMatches     LineMatch[]
  exceptions      MatchException[]
  exportBatches   ExportBatchItem[]

  reviewedBy      String?
  reviewedAt      DateTime?
  reviewNotes     String?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([vendorId])
  @@index([status])
}

model MatchSetDocument {
  id         String       @id @default(cuid())
  matchSetId String
  matchSet   MatchSet     @relation(fields: [matchSetId], references: [id], onDelete: Cascade)
  documentId String
  document   Document     @relation(fields: [documentId], references: [id])
  role       DocumentType

  @@unique([matchSetId, documentId])
}

enum LineMatchStatus {
  MATCHED
  DISCREPANCY
  MANUAL_MATCH
  UNMATCHED
}

model LineMatch {
  id                String           @id @default(cuid())
  matchSetId        String
  matchSet          MatchSet         @relation(fields: [matchSetId], references: [id], onDelete: Cascade)

  poLineItemId      String?
  poLineItem        DocumentLineItem? @relation("POLine", fields: [poLineItemId], references: [id])
  doLineItemId      String?
  doLineItem        DocumentLineItem? @relation("DOLine", fields: [doLineItemId], references: [id])
  invoiceLineItemId String?
  invoiceLineItem   DocumentLineItem? @relation("InvoiceLine", fields: [invoiceLineItemId], references: [id])

  matchScore        Float
  status            LineMatchStatus  @default(UNMATCHED)

  discrepancies     Json?

  @@index([matchSetId])
}

// ============ Exceptions & Export ============

enum ExceptionType {
  PRICE_DISCREPANCY
  QUANTITY_DISCREPANCY
  DESCRIPTION_MISMATCH
  MISSING_PO
  MISSING_DO
  MISSING_INVOICE
  VENDOR_MISMATCH
  DUPLICATE_DOCUMENT
  TAX_DISCREPANCY
  AMOUNT_MISMATCH
  UNRESOLVED_ITEM
}

enum ExceptionSeverity {
  HIGH
  MEDIUM
  LOW
}

model MatchException {
  id         String            @id @default(cuid())
  matchSetId String?
  matchSet   MatchSet?         @relation(fields: [matchSetId], references: [id])
  documentId String?
  document   Document?         @relation(fields: [documentId], references: [id])

  type       ExceptionType
  severity   ExceptionSeverity
  details    Json

  resolved   Boolean           @default(false)
  resolvedBy String?
  resolvedAt DateTime?
  resolution String?

  createdAt  DateTime @default(now())
}

model ExportBatch {
  id         String   @id @default(cuid())
  type       String
  exportedBy String
  exportedAt DateTime @default(now())
  fileUrl    String?
  items      ExportBatchItem[]
}

model ExportBatchItem {
  id            String      @id @default(cuid())
  exportBatchId String
  exportBatch   ExportBatch @relation(fields: [exportBatchId], references: [id])
  matchSetId    String
  matchSet      MatchSet    @relation(fields: [matchSetId], references: [id])

  @@unique([exportBatchId, matchSetId])
}

// ============ System Config ============

model ToleranceConfig {
  id                    String   @id @default(cuid())
  name                  String   @default("default")
  isDefault             Boolean  @default(false)
  vendorId              String?

  priceTolerancePct     Float    @default(3.0)
  qtyTolerancePct       Float    @default(5.0)
  taxTolerancePct       Float    @default(1.0)
  amountToleranceAbs    Float    @default(5.0)

  autoApproveThreshold  Float    @default(0.95)
  reviewThreshold       Float    @default(0.70)

  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}
